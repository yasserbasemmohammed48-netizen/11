        <div class="fg"><label>📱 رقم الطالب</label><div class="ph-row"><select class="pc" id="r-code"><option value="+966">🇸🇦 +966</option><option value="+965">🇰🇼 +965</option><option value="+971">🇦🇪 +971</option><option value="+20">🇪🇬 +20</option></select><input id="r-phone" placeholder="رقم الهاتف" style="flex:1"></div></div>
        <div class="fg"><label>👨‍👩‍👧 رقم ولي الأمر</label><div class="ph-row"><select class="pc" id="r-pcode"><option value="+966">🇸🇦 +966</option><option value="+965">🇰🇼 +965</option><option value="+971">🇦🇪 +971</option><option value="+20">🇪🇬 +20</option></select><input id="r-parent" placeholder="رقم الهاتف" style="flex:1"></div></div>
        <div class="fg"><label>🌍 الدولة</label><select id="r-country" onchange="onCC()"><option value="">-- اختر الدولة --</option><option value="sa">🇸🇦 المملكة العربية السعودية</option><option value="kw">🇰🇼 الكويت</option><option value="ae">🇦🇪 الإمارات</option><option value="eg">🇪🇬 مصر</option></select></div>
        <div class="fg" id="prov-g" style="display:none"><label>🏙️ المحافظة</label><select id="r-prov"></select></div>
        <button class="btn-f" onclick="rn1()">التالي ←</button>
      </div>
      <div class="sc" id="rs2">
        <div class="fg"><label>📚 السنة الدراسية</label><select id="r-grade" onchange="onGC()"><option value="">-- اختر --</option></select></div>
        <div id="subs-w" style="display:none"><label>📖 اختر المواد</label><div class="sg" id="subs-g"></div></div>
        <div style="display:flex;gap:8px;margin-top:8px"><button class="btn-back" onclick="rb1()">→ رجوع</button><button class="btn-f" style="flex:1;margin-top:0" onclick="rn2()">التالي ←</button></div>
      </div>
      <div class="sc" id="rs3">
        <div class="fg"><label>🔐 كلمة المرور</label><input type="password" id="r-pass" placeholder="6 أحرف على الأقل"></div>
        <div class="fg"><label>🔐 تأكيد كلمة المرور</label><input type="password" id="r-pass2" placeholder="أعد الإدخال"></div>
        <div style="display:flex;gap:8px;margin-top:8px"><button class="btn-back" onclick="rb2()">→ رجوع</button><button class="btn-f" style="flex:1;margin-top:0" onclick="doReg()">✅ إنشاء الحساب</button></div>
